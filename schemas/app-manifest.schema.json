{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://iammeter.github.io/appstore/schemas/app-manifest.schema.json",
  "title": "IAMMETER AppStore Manifest (v1.1)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "description",
    "version",
    "category",
    "type",
    "runtime",
    "tags",
    "links"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique app id (kebab-case). Should match folder name under apps/<id>/manifest.json",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "minLength": 3,
      "maxLength": 80
    },
    "name": { "type": "string", "minLength": 2, "maxLength": 80 },
    "description": { "type": "string", "minLength": 10, "maxLength": 300 },

    "author": {
      "type": "string",
      "description": "Optional author/maintainer name",
      "minLength": 2,
      "maxLength": 80
    },

    "version": {
      "type": "string",
      "description": "SemVer string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },

    "category": {
      "type": "string",
      "enum": ["monitoring", "control", "integration", "analytics", "tooling", "other"]
    },

    "type": {
      "type": "string",
      "enum": ["open-source", "proprietary"]
    },

    "runtime": {
      "type": "string",
      "enum": ["static", "hosted", "saas"]
    },

    "tags": {
      "type": "array",
      "description": "Tag list (e.g. template/example/static/hosted/official/community)",
      "items": { "type": "string", "minLength": 1, "maxLength": 30 },
      "minItems": 0,
      "maxItems": 20,
      "uniqueItems": true
    },

    "entry": {
      "type": "string",
      "description": "Optional entry file path relative to app folder (e.g. frontend/index.html)",
      "minLength": 1,
      "maxLength": 200,
      "pattern": "^(?!/)(?!.*\\\\)(?!.*\\s).+\\.html$"
    },

    "configSchema": {
      "type": "array",
      "description": "Optional. Keep for backward compatibility (array of schema items).",
      "items": {},
      "minItems": 0
    },

    "links": {
      "type": "object",
      "additionalProperties": false,
      "required": ["homepage"],
      "properties": {
        "homepage": { "type": "string", "format": "uri" },

        "preview": { "$ref": "#/definitions/urlOrRepoPath" },

        "docs": {
          "type": "string",
          "format": "uri",
          "description": "Docs MUST be an absolute URL in v1.1 (no repo-relative path)."
        },

        "source": { "type": "string", "format": "uri" },

        "screenshot": { "$ref": "#/definitions/urlOrRepoPath" }
      }
    }
  },

  "definitions": {
    "urlOrRepoPath": {
      "description": "Either a URL or a repo-relative path (no leading slash).",
      "anyOf": [
        { "type": "string", "format": "uri" },
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 300,
          "pattern": "^(?!/)(?!https?://)(?!.*\\\\)(?!.*\\s).+$"
        }
      ]
    }
  }
}