{
  "openapi": "3.0.0",
  "info": {
    "title": "IAMMETER Local API",
    "version": "1.0.0",
    "description": "IAMMETER Wi-Fi Energy Meter API Documentation"
  },
  "servers": [
    {
      "url": "http://10.10.30.35",
      "description": "Energy Meter Device"
    }
  ],
  "paths": {
    "/api/monitorjson": {
      "get": {
        "summary": "Get Monitor Data",
        "description": "Returns real-time measurement data: Voltage, Current, Active Power, Forward/Reverse kWh, Frequency, Power Factor",
        "responses": {
          "200": {
            "description": "Successfully returns monitoring data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "method": {
                      "type": "string"
                    },
                    "mac": {
                      "type": "string",
                      "description": "Device MAC address"
                    },
                    "version": {
                      "type": "string",
                      "description": "Firmware version"
                    },
                    "server": {
                      "type": "string",
                      "description": "Server mode"
                    },
                    "SN": {
                      "type": "string",
                      "description": "Device serial number"
                    },
                    "Datas": {
                      "type": "array",
                      "description": "Energy data [Phase A, Phase B, Phase C, NET Total]",
                      "items": {
                        "type": "array",
                        "items": {
                          "type": "number"
                        }
                      }
                    }
                  }
                },
                "example": {
                  "method": "2-9",
                  "mac": "A1B2C3D4E5F6",
                  "version": "i.91.063T2",
                  "server": "em",
                  "SN": "7F8A9B0C",
                  "Datas": [
                    [226.3, 1.41, 196, 424.546, 0, 49.99, 0.62],
                    [226.7, 1.41, 196, 424.397, 0, 49.99, 0.62],
                    [226.2, 1.42, 198, 428.223, 0, 49.99, 0.62]
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Failure response",
            "content": {
              "application/json": {
                "example": {
                  "method": "uploadsn",
                  "mac": null,
                  "version": null,
                  "server": null,
                  "SN": "null",
                  "Data": [null, null, null, null, null]
                }
              }
            }
          }
        }
      }
    },
    "/api/monitor": {
      "get": {
        "summary": "Get Monitor Data (Advanced)",
        "description": "Advanced version of monitorjson, includes Wi-Fi signal info",
        "responses": {
          "200": {
            "description": "Successfully returns monitoring data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ssid": {
                      "type": "string",
                      "description": "Wi-Fi SSID"
                    },
                    "sig": {
                      "type": "integer",
                      "description": "Wi-Fi signal strength"
                    },
                    "mac": {
                      "type": "string",
                      "description": "Device MAC address"
                    },
                    "version": {
                      "type": "string",
                      "description": "Firmware version"
                    },
                    "server": {
                      "type": "string",
                      "description": "Server mode"
                    },
                    "SN": {
                      "type": "string",
                      "description": "Device serial number"
                    },
                    "model": {
                      "type": "string",
                      "description": "Device model"
                    },
                    "Datas": {
                      "type": "array",
                      "description": "Energy data array",
                      "items": {
                        "type": "array",
                        "items": {
                          "type": "number"
                        }
                      }
                    }
                  }
                },
                "example": {
                  "ssid": "iammeter",
                  "sig": 100,
                  "mac": "A1B2C3D4E5F6",
                  "version": "i.91.063T2",
                  "server": "em",
                  "SN": "7F8A9B0C",
                  "model": "WEM3080T",
                  "Datas": [
                    [226.3, 1.42, 196, 424.49, 0, 50.01, 0.61],
                    [226.7, 1.42, 195, 424.34, 0, 50.01, 0.6],
                    [226.2, 1.43, 197, 428.166, 0, 50.01, 0.61]
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/netmetering": {
      "get": {
        "summary": "Get/Set Net Metering Mode",
        "description": "Get or set Net Energy Metering (NEM) mode. nem=1 enables NEM, nem=0 disables NEM. Without parameter returns current value, with parameter sets the value.",
        "parameters": [
          {
            "name": "nem",
            "in": "query",
            "description": "Net metering mode: 1=enable, 0=disable",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "1"
          }
        ],
        "responses": {
          "200": {
            "description": "Success response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "successful": {
                      "type": "boolean"
                    },
                    "nem": {
                      "type": "string",
                      "description": "Current net metering mode"
                    }
                  }
                },
                "example": {
                  "successful": true,
                  "nem": "1"
                }
              }
            }
          }
        }
      }
    },
    "/api/reactive": {
      "get": {
        "summary": "Get/Set Reactive Power Mode",
        "description": "Get or set Reactive Power (Q) and Reactive Energy (kVARh) measurement. x=1 enable, x=0 disable. Without parameter returns current value, with parameter sets the value.",
        "parameters": [
          {
            "name": "x",
            "in": "query",
            "description": "Reactive power mode: 1=enable, 0=disable",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "1"
          }
        ],
        "responses": {
          "200": {
            "description": "Success response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "successful": {
                      "type": "boolean"
                    },
                    "x": {
                      "type": "string",
                      "description": "Current reactive power mode"
                    }
                  }
                },
                "example": {
                  "successful": true,
                  "x": "1"
                }
              }
            }
          }
        }
      }
    },
    "/api/uploadinterval": {
      "get": {
        "summary": "Get/Set Upload Interval",
        "description": "Get or set upload interval (in seconds). Works in non-Cloud modes (TCP/HTTP/MQTT). Without parameter returns current value, with parameter sets the value.",
        "parameters": [
          {
            "name": "x",
            "in": "query",
            "description": "Upload interval (seconds)",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "60"
          }
        ],
        "responses": {
          "200": {
            "description": "Success response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "successful": {
                      "type": "boolean"
                    },
                    "x": {
                      "type": "string",
                      "description": "Current upload interval"
                    }
                  }
                },
                "example": {
                  "successful": true,
                  "x": "60"
                }
              }
            }
          }
        }
      }
    },
    "/api/wifidata": {
      "get": {
        "summary": "Get Wi-Fi Data",
        "description": "Returns Wi-Fi connection information",
        "responses": {
          "200": {
            "description": "Success response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ssid": {
                      "type": "string",
                      "description": "Wi-Fi SSID"
                    },
                    "sig": {
                      "type": "integer",
                      "description": "Wi-Fi signal strength"
                    }
                  }
                },
                "example": {
                  "ssid": "iammeter",
                  "sig": 100
                }
              }
            }
          }
        }
      }
    },
    "/api/ratio": {
      "get": {
        "summary": "Set CT Ratio",
        "description": "WEM3046T uses external CTs with 5A secondary outputs. Measured values (current, power, energy) must be multiplied by the CT ratio. Only available for WEM3046T.",
        "parameters": [
          {
            "name": "x",
            "in": "query",
            "description": "CT ratio, e.g., for 1000:5 enter 1000",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "1000"
          }
        ],
        "responses": {
          "200": {
            "description": "Success response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "successful": {
                      "type": "boolean"
                    },
                    "message": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "successful": true,
                  "message": "ok"
                }
              }
            }
          }
        }
      }
    },
    "/api/ctcratio": {
      "get": {
        "summary": "Get/Set CTC Ratio",
        "description": "Adjusts Phase C multiplier for split-phase/balanced scenarios. x=1 normal, x=2 doubles Phase C readings (current, power, kWh). Without parameter returns current value, with parameter sets the value.",
        "parameters": [
          {
            "name": "x",
            "in": "query",
            "description": "CTC ratio: 1 or 2",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [1, 2]
            },
            "example": "1"
          }
        ],
        "responses": {
          "200": {
            "description": "Success response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "successful": {
                      "type": "boolean"
                    },
                    "x": {
                      "type": "string",
                      "description": "Current CTC ratio"
                    }
                  }
                },
                "example": {
                  "successful": true,
                  "x": "1000"
                }
              }
            }
          }
        }
      }
    }
  }
}
